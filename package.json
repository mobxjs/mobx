{
    "name": "mobx-root",
    "private": true,
    "workspaces": [
        "packages/mobx",
        "packages/mobx-react-lite",
        "packages/mobx-react",
        "packages/eslint-plugin-mobx",
        "packages/mobx-undecorate"
    ],
    "overrides": {
        "jest": "^30.3.0",
        "typescript": "^5.9.2",
        "recast": "^0.23.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mobxjs/mobx.git"
    },
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "build:check": "npm run build:check --workspaces --if-present",
        "build:test": "npm run build:test --workspaces --if-present",
        "test": "jest",
        "coverage": "jest --coverage",
        "lint": "eslint packages/*/src/**/* --ext .js,.ts,.tsx",
        "prettier": "prettier --write **/*.{js,ts,md}",
        "release": "npm run prepublishOnly --workspaces --if-present && changeset publish",
        "mobx": "npm -w mobx run",
        "mobx-react": "npm -w mobx-react run",
        "mobx-react-lite": "npm -w mobx-react-lite run",
        "mobx-undecorate": "npm -w mobx-undecorate run",
        "eslint-plugin-mobx": "npm -w eslint-plugin-mobx run",
        "docs:build": "npm --prefix website run build",
        "docs:start": "npm --prefix website run start",
        "docs:publish": "npm --prefix website run publish-gh-pages",
        "prepare": "npm install --prefix website",
        "dedup": "npm dedupe"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.2.7",
        "@changesets/cli": "^2.11.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^5.16.4",
        "@testing-library/react": "^16.1.0",
        "@types/jest": "^30.0.0",
        "@types/node": "18",
        "@types/prop-types": "^15.5.2",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@typescript-eslint/eslint-plugin": "^5.0.0",
        "@typescript-eslint/parser": "^5.0.0",
        "coveralls": "^3.1.0",
        "eslint": "^6.8.0",
        "execa": "^4.1.0",
        "fs-extra": "9.0.1",
        "husky": "^4.2.5",
        "import-size": "^1.0.2",
        "iterall": "^1.3.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jest-mock-console": "^1.0.1",
        "lint-staged": "^10.1.7",
        "lodash": "^4.17.4",
        "minimist": "^1.2.5",
        "mkdirp": "1.0.4",
        "prettier": "^2.8.4",
        "pretty-quick": "3.1.0",
        "prop-types": "15.6.2",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "react-test-renderer": "19.0.0",
        "serializr": "^2.0.3",
        "tape": "^5.0.1",
        "ts-jest": "^29.4.6",
        "tsdx": "^0.14.1",
        "typescript": "^5.9.2"
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged"
        }
    }
}
